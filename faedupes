#!/usr/bin/env python

from collections import namedtuple
import argparse
import filecmp
import hashlib
import os
import pathlib
import sqlite3
import sys
import time

DB_PATH = pathlib.Path.home() / ".config/faedupes/db"

DbFile = namedtuple('DbFile',
    field_names=['path', 'size', 'ctime', 'hash'],
    defaults=[None])

argparser = argparse.ArgumentParser(allow_abbrev=False)
argparser.add_argument('--quick',     action="store_true")
argparser.add_argument('--reference', action="store_true")
argparser.add_argument('--verbose', '-v', action="count", default=0)
argparser.add_argument('--write-script', type=pathlib.Path, metavar="PATH")
args = argparser.parse_args()

db_has_changed = False

def vprint(msg):
  if args.verbose:
    print(msg)

def fmt_size(size_bytes):
  for unit in ['B', 'KiB', 'MiB', 'GiB']:
    if size_bytes < 1024:
      return f"{size_bytes:.2f} {unit}"
    size_bytes /= 1024

def dbcon(autocommit=False):
  con = sqlite3.connect(DB_PATH, autocommit=autocommit)
  if args.verbose >= 2:
    con.set_trace_callback(print)
  return con

def db_changed():
  global db_has_changed
  db_has_changed = True

def db_cleanup():
  global db_has_changed
  if not db_has_changed:
    return
  with dbcon(autocommit=True) as db:
    print("Optimising DB...")
    db.execute("VACUUM")
    db.execute("ANALYZE")

def db_mktables():
  pathlib.Path(DB_PATH).parent.mkdir(parents=True, exist_ok=True)
  with dbcon(autocommit=True) as db:
    db.execute("PRAGMA journal_mode = WAL")
    db.execute("PRAGMA synchronous = NORMAL")
    db.execute("PRAGMA temp_store = MEMORY")

    db.execute("CREATE TABLE IF NOT EXISTS files("
               "path TEXT PRIMARY KEY NOT NULL,"
               "size INTEGER NOT NULL,"
               "ctime INTEGER NOT NULL,"
               "hash TEXT)")

# these indexes are for:
# EXPLAIN QUERY PLAN SELECT size FROM files WHERE path LIKE '/some/file/path/%' ESCAPE '\' GROUP BY size HAVING COUNT(*) > 1;
# EXPLAIN QUERY PLAN SELECT hash FROM files WHERE hash IS NOT NULL GROUP BY hash HAVING COUNT(*) > 1;
# EXPLAIN QUERY PLAN SELECT path, size, ctime, hash FROM files WHERE hash='some hash';
    db.execute("CREATE INDEX IF NOT EXISTS files_path_size_idx "
               "ON files (path,size)")
    db.execute("CREATE INDEX IF NOT EXISTS files_hash_idx "
               "ON files (hash,path,size,ctime) WHERE hash IS NOT NULL")


def db_check_files_exist(db, dbfs):
  keep = []
  to_rm = []
  for dbf in dbfs:
    if os.path.lexists(dbf.path):
      keep += [dbf]
    else:
      to_rm += [(dbf.path,)]
  if len(to_rm) > 0:
    db.executemany("DELETE FROM files WHERE path=?", to_rm)
    db.commit()
    db_changed()
  return keep

def db_get_file(db, path):
  rows = list(db.execute(
      "SELECT path, size, ctime, hash FROM files"
      f" WHERE path = ?", (str(path),)))
  if len(rows) == 0:
    return None
  elif len(rows) > 1:
    raise Error(f"Multiple rows for: {path}")
  row = rows[0]
  return DbFile(row[0], row[1], row[2], row[3])

def db_add_files(db, paths_stats):
  if len(paths_stats) < 1:
    return

  rows = [(str(path), stat.st_size, stat.st_ctime)
          for path, stat in paths_stats]
  db.executemany(
      "INSERT INTO files (path, size, ctime) VALUES (?, ?, ?)", rows)
  db.commit()
  db_changed()

def db_update_files(db, paths_stats):
  if len(paths_stats) < 1:
    return

  rows = [(stat.st_size, stat.st_ctime, str(path))
          for path, stat in paths_stats]
  db.executemany(
      "UPDATE files SET size=?, ctime=?, hash=null WHERE path=?", rows)
  db.commit()
  db_changed()

def escape_path_for_like(path):
  like = str(path) + "/"
  like = like.replace("\\", "\\\\")
  like = like.replace("%", r"\%")
  like = like.replace("_", r"\_")
  like += "%"
  return like

def db_files_with_sizes_from_dir(db, root):
  # TODO investigate creating a temp table for dupe sizes?
  like = escape_path_for_like(root)
  rows = list(db.execute(
      "SELECT path, size, ctime, hash FROM files WHERE"
      " size IN (SELECT size FROM files  WHERE path LIKE ? ESCAPE ?)"
      " AND size IN (SELECT size FROM files GROUP BY size HAVING COUNT(*) > 1)",
      (like, "\\")))
  return [DbFile(r[0], r[1], r[2], r[3]) for r in rows]

def db_files_with_dupe_hashes_in_dir(db, root):
  # TODO investigate creating a temp table for directory
  like = escape_path_for_like(root)
  rows = list(db.execute(
      "SELECT path, size, ctime, hash FROM files"
      " WHERE path LIKE ? ESCAPE ? AND hash IN"
      " (SELECT hash FROM files"
      "  WHERE hash IS NOT NULL"
      "  GROUP BY hash HAVING COUNT(*) > 1)"
      "ORDER BY path ASC",
      (like, "\\")))
  return [DbFile(r[0], r[1], r[2], r[3]) for r in rows]

def db_files_with_hash(db, hsh):
  rows = list(db.execute(
      "SELECT path, size, ctime, hash FROM files"
      " WHERE hash=? ORDER BY path ASC", (hsh,)))
  return [DbFile(r[0], r[1], r[2], r[3]) for r in rows]

def update_files(db, paths):
  to_add = []
  to_update = []

  for path in paths:
    stat = path.stat()
    if stat.st_size == 0:
      continue

    dbf = db_get_file(db, path)
    if dbf is None:
      to_add += [(path, stat)]
    elif dbf.size != stat.st_size or dbf.ctime != stat.st_ctime:
      to_update += [(path, stat)]

  db_add_files(db, to_add)
  db_update_files(db, to_update)

  if len(to_add) or len(to_update):
    print(f"Files added, updated: {len(to_add)}, {len(to_update)}")

def walk_files(start):
  with dbcon() as db:
    all_paths = []
    for root, dirs, files in start.walk():
      paths = [start / root / f for f in files]
      paths = [p for p in paths if p.is_file(follow_symlinks=False)]
      paths = [p.resolve() for p in paths]
      all_paths += paths
    print(f"Files here: {len(all_paths)}")
    update_files(db, all_paths)

def sha1(path):
  with open(path, 'rb', buffering=0) as f:
    return hashlib.file_digest(f, 'sha1').hexdigest()

def update_hashes(db, dbfs):
  to_hash = []
  for dbf in dbfs:
    stat = pathlib.Path(dbf.path).stat()
    if (dbf.hash is None
        or dbf.size != stat.st_size
        or dbf.ctime != stat.st_ctime):
      to_hash += [(dbf, stat)]

  if len(to_hash) < 1:
    return
  size = sum([f.size for f, s in to_hash])
  print(f"To hash: {len(to_hash)} files, {fmt_size(size)}")

  rows = []
  batch_start = time.monotonic()
  def write_rows():
    if len(rows) < 1:
      return

    db.executemany("UPDATE files SET hash=?,size=?,ctime=? WHERE path=?", rows)
    db.commit()
    db_changed()
    dur = int(time.monotonic() - batch_start)
    print(f"Hashed: {len(rows)} / {dur} seconds")
    rows.clear()

  for dbf, stat in to_hash:
    rows += [(sha1(dbf.path), stat.st_size, stat.st_ctime, dbf.path)]
    if time.monotonic() - batch_start > 10:
      write_rows()
      batch_start = time.monotonic()
  write_rows()

# if it is safe to delete the file, return the file that is being kept.
# returns None if it is not a dupe and therefore is not safe to delete.
def safety_check(db, dbf_to_check, root):
  with_hash = db_files_with_hash(db, dbf_to_check.hash)
  if len(with_hash) < 2:
    print(f"ERROR: Files with same hash gone missing: {dbf_to_check.hash}")
    sys.exit(1)

  for dbf in with_hash:
    if not os.path.exists(dbf.path):
      print(f"ERROR: Other file does not exist: {dbf.path}")
      sys.exit(1)

    if not os.path.isfile(dbf.path):
      print(f"ERROR: Not a regular file: {dbf.path}")
      sys.exit(1)

    if os.path.islink(dbf.path):
      print(f"ERROR: Is a symlink: {dbf.path}")
      sys.exit(1)

  others = [f for f in with_hash
            if not os.path.samefile(dbf_to_check.path, f.path)]
  if len(others) < 1:
    print(f"ERROR: Other files were actually all the same file:")
    print(f"File: {dbf_to_check.path}")
    print("Others:")
    print("\n".join([f.path for f in with_hash]))
    sys.exit(1)

  root = root.resolve()
  def is_in_root(path):
    p = pathlib.Path(path).resolve()
    return p.is_relative_to(root)

  outsiders = [o for o in others if not is_in_root(o.path)]
  if len(outsiders) < 1:
    if args.verbose:
      print(f"WARNING: Other files are all under this directory:")
      print(f"File: {dbf_to_check.path}")
      print("Others:")
      print("\n".join([o.path for o in others]))
    return None

  keep = None
  if args.quick:
    keep = outsiders[0]
  else:
    for o in outsiders:
      if filecmp.cmp(dbf_to_check.path, o.path, shallow=False):
        keep = o
        break

  if keep is None and args.verbose:
    print(f"WARNING: Failed to find an exact keep file in:")
    print("\n".join([o.path for o in outsiders]))

  return keep

def find_dupes(root):
  with dbcon() as db:
    size_dupes = db_files_with_sizes_from_dir(db, root)
    size_dupes = db_check_files_exist(db, size_dupes)
    vprint(f"Size dupes: {len(size_dupes)}")

    update_hashes(db, size_dupes)
    hash_dupes = db_files_with_dupe_hashes_in_dir(db, root)
    vprint(f"Hash dupes: {len(hash_dupes)}")

  script = [
      "#!/usr/bin/env bash",
      "set -eu",
  ]
  def add_to_script(dbf, keep):
    if not args.write_script:
      return
    # all on one like to make it easy to grep/filter.
    script.append(f"rm -v \"{dbf.path.replace('"', r'\"')}\" # {keep.path}")

  dupe_count = 0
  dupe_size = 0
  with dbcon() as db:
    for dbf in hash_dupes:
      keep = safety_check(db, dbf, root)
      if keep is not None:
        rel_path = os.path.relpath(dbf.path, root)
        print(f"{rel_path}  ({keep.path})")
        add_to_script(dbf, keep)
        dupe_count += 1
        dupe_size += dbf.size
  print(f"Dupes: {dupe_count} files, {fmt_size(dupe_size)}")

  if args.write_script and dupe_count > 0:
    script_path = pathlib.Path(args.write_script)
    with open(script_path, 'w') as f:
      f.write("\n".join(script))
    print(f"Wrote script: {script_path}")

def cleanup_and_exit():
  db_cleanup()
  sys.exit(0)

if __name__ == '__main__':
  db_mktables()

  pwd = pathlib.Path(".").resolve(strict=True)
  walk_files(pwd)

  if args.reference:
    print("Reference Mode: Skipping dupe search.")
    cleanup_and_exit()

  if args.quick:
    print("Quick Mode: Skipping byte-for-byte file comparisons.")

  find_dupes(pwd)
  cleanup_and_exit()
